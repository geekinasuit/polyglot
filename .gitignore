# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Generated files
*.pb.go

# JOOQ generated sources (produced by //kotlin:jooq_generated_srcs genrule)
kotlin/com/geekinasuit/polyglot/brackets/db/jooq/

# Dependency directories (remove the comment below to include it)
# vendor/


# env file
.env

# Bazel files
.ijwb
.aswb
bazel-*
MODULE.bazel.lock
.idea
.bazelbsp

# Output files

target
out

# Override global gitignore exclusions for project-tracked directories
!thoughts
!AGENTS.md